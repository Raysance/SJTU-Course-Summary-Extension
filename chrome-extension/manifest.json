{
  "manifest_version": 3,
  "name": "SJTU 课程资料助手",
  "version": "4.8.7",
  "description": "从 SJTU Canvas 自动读取课堂视频字幕生成笔记，并识别课程文件，支持勾选后一键打包下载 ZIP。",
  "permissions": ["downloads", "storage", "tabs", "scripting", "webRequest"],
  "host_permissions": [
    "https://oc.sjtu.edu.cn/*",
    "https://s3.jcloud.sjtu.edu.cn/*",
    "https://v.sjtu.edu.cn/jy-application-canvas-sjtu-ui/*",
    "https://api.deepseek.com/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_title": "打开 SJTU 课程资料助手"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://v.sjtu.edu.cn/jy-application-canvas-sjtu-ui/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://oc.sjtu.edu.cn/courses/*/files*"
      ],
      "js": ["files-content.js"],
      "run_at": "document_idle"
    }
  ]
}
