{
  "manifest_version": 3,
  "name": "SJTU 课堂概要导出",
  "version": "4.7.0",
  "description": "从已登录的 SJTU Canvas 自动识别课堂视频并读取平台字幕，按日期整理并用多种 AI 服务生成课堂笔记。",
  "key": "",
  "permissions": ["downloads", "storage", "tabs", "scripting"],
  "host_permissions": [
    "https://oc.sjtu.edu.cn/*",
    "https://v.sjtu.edu.cn/jy-application-canvas-sjtu-ui/*",
    "https://api.deepseek.com/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_title": "打开 SJTU 课堂概要导出"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": [
      "https://v.sjtu.edu.cn/jy-application-canvas-sjtu-ui/*"
    ],
    "js": ["content.js"],
    "run_at": "document_idle"
  }]
}
